rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isActiveUser() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isModerator() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }

    function isAdminOrModerator() {
      return isAdmin() || isModerator();
    }

    function isSameGroup(groupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId == groupId;
    }

    function isActiveUserOrAdmin() {
      return isActiveUser() || isAdmin();
    }

    function isActiveSameGroupResource() {
      return isActiveUser() &&
        resource.data.status == 'active' &&
        resource.data.groupId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    function isSameGroupResource() {
      return isActiveUser() &&
        resource.data.groupId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    function isSameGroupId(groupId) {
      return isActiveUser() &&
        groupId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId;
    }

    function canMarkInviteUsed() {
      return isSignedIn() &&
        resource.data.status == 'created' &&
        request.resource.data.status == 'used' &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']);
    }

    // ─── Users ────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId
        && !('platformAdmin' in request.resource.data);
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isAdmin() ||
        isActiveSameGroupResource()
      );
      // Admins can update any field except platformAdmin.
      // Moderators can update status/displayName/etc but cannot change role.
      // Users can update their own doc.
      allow update: if isSignedIn() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['platformAdmin']) &&
        (
          request.auth.uid == userId ||
          isAdmin() ||
          (isModerator() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        );
      allow delete: if isAdmin();
    }

    // ─── Groups ───────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow get: if true;
      allow list: if isActiveUser() && isSameGroup(groupId);
      // Only admins can change group settings, season config, points table, etc.
      allow write: if isAdmin();

      // ─── Course Corrections (subcollection) ───────────────────────────

      match /courseCorrections/{correctionId} {
        allow read: if isAdminOrModerator() && isSameGroup(groupId);
        allow write: if isAdminOrModerator() && isSameGroup(groupId);
      }
    }

    // ─── Members ──────────────────────────────────────────────────────────

    match /members/{memberId} {
      allow read: if isActiveUserOrAdmin();
      // Moderators can update member records (handicap, stats, season points).
      allow write: if isAdminOrModerator();
    }

    // ─── Member Invites ──────────────────────────────────────────────────

    match /memberInvites/{inviteId} {
      allow get: if true;
      allow list, create, delete: if isAdminOrModerator();
      allow update: if isAdminOrModerator() || canMarkInviteUsed();
    }

    // ─── Courses ──────────────────────────────────────────────────────────

    match /courses/{courseId} {
      allow read: if isActiveUserOrAdmin();
      allow write: if isAdminOrModerator();
    }

    // ─── Rounds ───────────────────────────────────────────────────────────

    match /rounds/{roundId} {
      allow read: if isActiveUserOrAdmin();
      // Moderators can create and edit rounds but cannot delete them.
      allow create, update: if isAdminOrModerator();
      allow delete: if isAdmin();

      match /teeTimes/{teeTimeId} {
        allow read: if isActiveUserOrAdmin();
        allow write: if isAdminOrModerator();
      }

      match /rsvps/{memberId} {
        allow read: if isActiveUserOrAdmin();
        allow create: if isAdminOrModerator() || (
          isActiveUser() &&
          request.auth.uid == memberId &&
          request.resource.data.memberId == request.auth.uid
        );
        allow update: if isAdminOrModerator() || (
          isActiveUser() &&
          request.auth.uid == memberId &&
          resource.data.memberId == request.auth.uid &&
          request.resource.data.memberId == request.auth.uid
        );
        allow delete: if isAdminOrModerator();
      }

      match /sideClaims/{claimId} {
        allow read: if isActiveUserOrAdmin();
        allow create, update: if isActiveUserOrAdmin() &&
          request.resource.data.updatedBy == request.auth.uid &&
          request.resource.data.roundId == roundId &&
          get(/databases/$(database)/documents/rounds/$(roundId)).data.resultsPublished != true;
        allow delete: if isAdminOrModerator();
      }
    }

    // ─── Scorecards ───────────────────────────────────────────────────────

    match /scorecards/{scorecardId} {
      allow read: if isAdminOrModerator() || (
        isActiveUser() &&
        (
          resource.data.playerId == request.auth.uid ||
          resource.data.markerId == request.auth.uid ||
          isSameGroupResource()
        )
      );
      allow create: if isActiveUser() && (
        request.resource.data.playerId == request.auth.uid ||
        request.resource.data.markerId == request.auth.uid ||
        isAdminOrModerator()
      );
      allow update: if isActiveUser() && (
        (resource.data.playerId == request.auth.uid && resource.data.status != 'admin_locked') ||
        (resource.data.markerId == request.auth.uid && resource.data.status != 'admin_locked') ||
        isAdminOrModerator()
      );
      allow delete: if isAdminOrModerator();

      match /holeScores/{holeNumber} {
        allow read: if isActiveUserOrAdmin();
        allow write: if isActiveUserOrAdmin();
      }
    }

    // ─── Results ──────────────────────────────────────────────────────────

    match /results/{resultId} {
      allow read: if isActiveUserOrAdmin();
      allow write: if isAdminOrModerator();
    }

    // ─── Season Standings ─────────────────────────────────────────────────

    match /seasonStandings/{standingId} {
      allow read: if isActiveUserOrAdmin();
      allow write: if isAdminOrModerator();
    }

    // ─── Handicap History ─────────────────────────────────────────────────

    match /handicapHistory/{historyId} {
      allow read: if isActiveUserOrAdmin();
      allow write: if isAdminOrModerator();
    }

    // ─── Posts ────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isActiveUserOrAdmin();
      // Announcements remain admin-only. Moderators can post general content.
      allow create: if isActiveUser() && (
        request.resource.data.type != 'announcement' || isAdmin()
      );
      allow update: if isActiveUser() && (
        isAdminOrModerator() ||
        (
          resource.data.authorId == request.auth.uid &&
          isSameGroupId(resource.data.groupId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'content',
            'updatedAt'
          ])
        ) ||
        (
          isSameGroupId(resource.data.groupId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reactionCounts',
            'commentCount',
            'updatedAt'
          ])
        )
      );
      allow delete: if isAdminOrModerator() ||
        resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isActiveUserOrAdmin();
        allow create: if isActiveUser();
        allow delete: if isAdminOrModerator() ||
          resource.data.authorId == request.auth.uid;
      }

      match /reactions/{reactionId} {
        allow read: if isActiveUserOrAdmin();
        allow write: if isActiveUser();
      }
    }

    // ─── Photos ───────────────────────────────────────────────────────────

    match /photos/{photoId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
      allow delete: if isAdminOrModerator() ||
        resource.data.uploaderId == request.auth.uid;
    }

    // ─── Notifications ────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isAdminOrModerator() || (
        isSignedIn() &&
        resource.data.recipientId == request.auth.uid
      );
      allow update: if isAdminOrModerator() || (
        isSignedIn() &&
        resource.data.recipientId == request.auth.uid
      );
      // Admins/moderators can create any notification (e.g. round announcements).
      // Members can create comment/reaction notifications for others in their group.
      allow create: if isAdminOrModerator() || (
        isActiveUser() &&
        isSameGroupId(request.resource.data.groupId) &&
        request.resource.data.recipientId != request.auth.uid &&
        request.resource.data.type in ['new_comment', 'new_reaction'] &&
        request.resource.data.read == false
      );
      allow delete: if isAdminOrModerator();
    }
  }
}
